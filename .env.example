# ===========================================
# AIKeyHive - Environment Variables
# ===========================================

# --- Auth.js ---
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_URL="http://localhost:3000"

# --- OIDC Provider Configuration ---
# Works with any OIDC-compliant IdP: Okta, Google Workspace, Microsoft Entra ID, etc.
AUTH_OIDC_ISSUER="https://your-idp.example.com"
AUTH_OIDC_CLIENT_ID="your-client-id"
AUTH_OIDC_CLIENT_SECRET="your-client-secret"

# Optional: restrict login to a specific email domain
# ALLOWED_EMAIL_DOMAIN="example.com"

# First admin user - this email gets admin role on first login
# INITIAL_ADMIN_EMAIL="admin@example.com"

# --- Okta Example ---
# AUTH_OIDC_ISSUER="https://your-org.okta.com"
# AUTH_OIDC_CLIENT_ID="0oa..."
# AUTH_OIDC_CLIENT_SECRET="..."

# --- Google Workspace Example ---
# AUTH_OIDC_ISSUER="https://accounts.google.com"
# AUTH_OIDC_CLIENT_ID="...apps.googleusercontent.com"
# AUTH_OIDC_CLIENT_SECRET="GOCSPX-..."

# --- Microsoft Entra ID Example ---
# AUTH_OIDC_ISSUER="https://login.microsoftonline.com/{tenant-id}/v2.0"
# AUTH_OIDC_CLIENT_ID="..."
# AUTH_OIDC_CLIENT_SECRET="..."

# --- Database (Turso / libSQL) ---
# Local development: file:local.db
# Turso remote: libsql://your-db-name-your-org.turso.io
DATABASE_URL="file:local.db"
DATABASE_AUTH_TOKEN=""

# --- OpenAI Admin API ---
# OPENAI_ADMIN_KEY="sk-admin-..."
# OPENAI_ORG_ID="org-..."

# --- Anthropic Admin API ---
# ANTHROPIC_ADMIN_KEY="sk-ant-admin-..."
# ANTHROPIC_ORG_ID="..."
# ANTHROPIC_WORKSPACE_ID="wrkspc_..."  # AIKeyHive workspace ID for key pool filtering

# --- GCP / Gemini ---
# GOOGLE_PROJECT_ID="your-gcp-project"
# Local: file path works via ADC
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"
# Vercel/serverless: paste the full JSON content of the service account key
# GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key":"...",...}'

# --- BigQuery (Gemini cost sync) ---
# BIGQUERY_BILLING_TABLE="project.dataset.gcp_billing_export_v1_XXXXXX"

# --- Key Encryption (required for Anthropic key pool) ---
# Generate with: openssl rand -hex 32
KEY_ENCRYPTION_KEY=""

# --- Cron Security ---
# CRON_SECRET="your-cron-secret"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
